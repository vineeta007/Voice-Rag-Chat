{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VoiceRAGBenchmarkEntry",
  "type": "object",
  "required": [
    "id",
    "question",
    "language",
    "category",
    "gold_answer",
    "gold_chunk_ids",
    "requires_abstain"
  ],
  "properties": {
    "id": { "type": "string" },
    "pair_id": { "type": "string" },
    "question": { "type": "string" },
    "language": { "type": "string", "enum": ["English", "Hindi"] },
    "category": { "type": "string" },
    "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
    "gold_answer": { "type": "string" },
    "gold_chunk_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requires_abstain": { "type": "boolean" },
    "notes": { "type": "string" }
  }
}
