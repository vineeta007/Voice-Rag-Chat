
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/google-cloud-key.json
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs TTS (optional - enables natural voices)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Optional: set custom voice IDs for each language
ELEVENLABS_VOICE_ID_EN=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_ID_HI=EXAVITQu4vr4xnSDxMaL

# Qdrant Cloud configuration
QDRANT_URL=your_qdrant_cloud_url_here
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=uit_rag
